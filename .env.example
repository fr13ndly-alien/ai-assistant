# GoClaw runtime
GOCLAW_GATEWAY_TOKEN=
GOCLAW_ENCRYPTION_KEY=
GOCLAW_OPENAI_API_KEY=
GOCLAW_TELEGRAM_TOKEN=

# Docker-managed external services
POSTGRES_USER=goclaw
POSTGRES_PASSWORD=
POSTGRES_DB=goclaw
POSTGRES_PORT=5432
CALENDAR_MCP_PORT=3000

# Google Calendar MCP (only needed when the optional "calendar" Docker profile is enabled)
# Optional override for the Desktop OAuth credentials JSON from Google Cloud.
# If left empty, Docker Compose defaults to ./.secrets/gcp-oauth.keys.json
GOOGLE_OAUTH_CREDENTIALS_PATH=
